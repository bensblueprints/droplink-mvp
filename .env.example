# Droplink configuration
# Copy to .env (or set as environment variables) — all optional except ADMIN_PASSWORD before deploying publicly.

# Port the server listens on
PORT=5332

# Password for the /admin panel. CHANGE THIS before deploying publicly.
ADMIN_PASSWORD=admin

# Where the SQLite database + uploaded files live (defaults to ./data)
# DATA_DIR=/var/lib/droplink
# DB_PATH=/var/lib/droplink/app.db

# Public base URL used in emailed links (defaults to the request's own host)
# BASE_URL=https://files.yourdomain.com

# Storage quota, in GB. Uploads that would exceed this are rejected at session-create time.
STORAGE_QUOTA_GB=10

# How often the cleanup sweep runs (ms). Deletes expired/limit-hit transfers + orphaned uploads >24h old.
# CLEANUP_INTERVAL_MS=300000

# BYO SMTP for emailing share links. Leave unset to disable emailing (admin UI shows a warning banner).
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Droplink <you@yourdomain.com>
